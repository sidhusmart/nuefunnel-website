---
const currentYear = new Date().getFullYear();
---

<footer class="py-10 mt-24 border-t border-border">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <p class="text-sm text-subtle">
        &copy; nuefunnel LLC. {currentYear}
      </p>

      <div class="flex items-center gap-6">
        <a
          href="https://x.com/nuefunnel"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-body hover:text-ink"
        >
          Twitter
        </a>
        <a
          href="https://www.linkedin.com/company/nuefunnel/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-body hover:text-ink"
        >
          LinkedIn
        </a>
        <a
          href="mailto:contact@nuefunnel.com"
          class="text-sm text-body hover:text-ink"
        >
          Email
        </a>
      </div>
    </div>
  </div>
</footer>
