---
const currentYear = new Date().getFullYear();
---

<footer class="py-6 mt-20">
  <div class="container-custom">
    <div class="flex flex-col md:flex-row justify-between items-center gap-4">
      <!-- Copyright -->
      <p class="text-sm text-gray-500">
        &copy; nuefunnel LLC. {currentYear}
      </p>

      <!-- Social Links -->
      <div class="flex items-center gap-6">
        <a
          href="https://x.com/nuefunnel"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-accent-cyan hover:underline transition-colors"
        >
          Twitter
        </a>
        <a
          href="https://www.linkedin.com/company/nuefunnel/"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-accent-cyan hover:underline transition-colors"
        >
          LinkedIn
        </a>
        <a
          href="mailto:contact@nuefunnel.com"
          class="text-sm text-accent-cyan hover:underline transition-colors"
        >
          Email
        </a>
      </div>
    </div>
  </div>
</footer>
