---
const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 bg-white border-b border-gray-200 z-50">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a href="/" class="text-2xl font-bold text-gray-900 hover:text-primary transition-colors">
        nuefunnel
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="/products"
          class={`font-medium transition-colors ${currentPath === '/products' ? 'text-primary' : 'text-gray-700 hover:text-primary'}`}
        >
          Products
        </a>
        <a
          href="/customer-stories"
          class={`font-medium transition-colors ${currentPath === '/customer-stories' ? 'text-primary' : 'text-gray-700 hover:text-primary'}`}
        >
          Customer Stories
        </a>
        <a
          href="/blog"
          class={`font-medium transition-colors ${currentPath === '/blog' ? 'text-primary' : 'text-gray-700 hover:text-primary'}`}
        >
          Blog
        </a>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Request Demo
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-gray-200 pt-4">
      <div class="flex flex-col gap-4">
        <a href="/products" class="font-medium text-gray-700 hover:text-primary">
          Products
        </a>
        <a href="/customer-stories" class="font-medium text-gray-700 hover:text-primary">
          Customer Stories
        </a>
        <a href="/blog" class="font-medium text-gray-700 hover:text-primary">
          Blog
        </a>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-block text-center"
        >
          Request Demo
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
