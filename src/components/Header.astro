---
const currentPath = Astro.url.pathname;
const isHomepage = currentPath === '/';
---

<header class="fixed top-0 left-0 right-0 bg-white z-50" style="box-shadow: rgba(136, 136, 136, 0.25) 5px 5px 2px 0px;">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <!-- Logo -->
      <a
        href="/"
        class={`font-logo text-xl uppercase tracking-normal transition-colors ${isHomepage ? 'text-gray-900' : 'text-accent-cyan'}`}
      >
        NUEFUNNEL
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        <a
          href="/products"
          class={`font-medium transition-colors text-accent-cyan hover:opacity-80 ${currentPath === '/products' || currentPath === '/' ? 'underline underline-offset-4' : ''}`}
        >
          Products
        </a>
        <a
          href="/customer-stories"
          class={`font-medium transition-colors text-accent-cyan hover:opacity-80 ${currentPath.startsWith('/customer-stories') ? 'underline underline-offset-4' : ''}`}
        >
          Customer Stories
        </a>
        <a
          href="/blog"
          class={`font-medium transition-colors text-accent-cyan hover:opacity-80 ${currentPath.startsWith('/blog') ? 'underline underline-offset-4' : ''}`}
        >
          Blog
        </a>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Request Demo
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-btn"
        class="md:hidden p-2"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <!-- Mobile Navigation -->
    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-gray-200 pt-4">
      <div class="flex flex-col gap-4">
        <a href="/products" class={`font-medium text-accent-cyan ${currentPath === '/products' ? 'underline' : ''}`}>
          Products
        </a>
        <a href="/customer-stories" class={`font-medium text-accent-cyan ${currentPath.startsWith('/customer-stories') ? 'underline' : ''}`}>
          Customer Stories
        </a>
        <a href="/blog" class={`font-medium text-accent-cyan ${currentPath.startsWith('/blog') ? 'underline' : ''}`}>
          Blog
        </a>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-block text-center"
        >
          Request Demo
        </a>
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
