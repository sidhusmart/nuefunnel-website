---
const currentPath = Astro.url.pathname;

const navItems = [
  { href: '/work', label: 'Work' },
  { href: '/products', label: 'Products' },
  { href: '/blog', label: 'Blog' },
  { href: '/about', label: 'About' },
];

function isActive(href: string) {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(href + '/');
}
---

<header class="fixed top-0 left-0 right-0 bg-paper/90 backdrop-blur-sm z-50 border-b border-border">
  <nav class="container-custom py-4">
    <div class="flex items-center justify-between">
      <a
        href="/"
        class="font-tight text-lg font-semibold text-ink tracking-tight lowercase hover:text-ink"
      >
        nuefunnel
      </a>

      <div class="hidden md:flex items-center gap-8">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`font-medium transition-colors ${isActive(item.href) ? 'text-ink underline underline-offset-4 decoration-2' : 'text-body hover:text-ink'}`}
          >
            {item.label}
          </a>
        ))}
      </div>

      <button
        id="mobile-menu-btn"
        class="md:hidden p-2 text-ink"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path>
        </svg>
      </button>
    </div>

    <div id="mobile-menu" class="hidden md:hidden mt-4 pb-4 border-t border-border pt-4">
      <div class="flex flex-col gap-4">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`font-medium ${isActive(item.href) ? 'text-ink underline' : 'text-body'}`}
          >
            {item.label}
          </a>
        ))}
      </div>
    </div>
  </nav>
</header>

<script>
  const mobileMenuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  mobileMenuBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>
