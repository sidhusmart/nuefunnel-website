---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Products" description="Discover nuefunnel's AI-powered API assistance products">
  <section class="py-20 px-4">
    <div class="container-custom max-w-desktop">
      <h1 class="text-5xl font-bold text-gray-900 mb-6">Our Products</h1>
      <p class="text-xl text-gray-600 mb-12 max-w-3xl">
        Explore our suite of AI-powered tools designed to simplify API integration
        and enhance developer experience.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl">
        <!-- Product 1 -->
        <div class="card p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">API Chat Assistant</h3>
          <p class="text-gray-600 mb-6">
            Interactive AI assistant that helps developers understand and integrate your APIs
            with natural language conversations.
          </p>
          <a href="https://tally.so/r/w2JM7g" class="text-primary font-medium hover:underline">
            Learn more →
          </a>
        </div>

        <!-- Product 2 -->
        <div class="card p-8 shadow-lg">
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Documentation Enhancement</h3>
          <p class="text-gray-600 mb-6">
            Automatically fill documentation gaps and provide contextual, dynamic responses
            based on your API structure.
          </p>
          <a href="https://tally.so/r/w2JM7g" class="text-primary font-medium hover:underline">
            Learn more →
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
