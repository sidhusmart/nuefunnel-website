---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { components } from '../components/MDXComponents';
import ProductLogo from '../components/ProductLogo.astro';

// Single source of truth for products (shared with the home-page highlight).
// There are no per-product detail pages: each entry's MDX body renders inline
// here, and the "Visit" button points at the product's own external site.
const entries = (await getCollection('products', ({ data }) => !data.draft))
  .sort((a, b) => a.data.order - b.data.order);

// render() is async and per-entry, so resolve every body up front.
const products = await Promise.all(
  entries.map(async (entry) => {
    const { Content } = await entry.render();
    return { data: entry.data, Content };
  })
);
---

<Layout title="Products" description="Products from the nuefunnel studio — built mostly because we needed them ourselves.">
  <section class="pt-28 md:pt-36 pb-16 px-4">
    <div class="container-custom max-w-desktop">
      <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-3">
        Products
      </p>
      <h1 class="font-tight text-4xl md:text-6xl font-semibold text-ink max-w-4xl leading-[1.05]">
        Things we've built, mostly because we needed them.
      </h1>
      <p class="mt-6 text-lg md:text-xl text-body max-w-2xl leading-relaxed">
        Two products have come out of the studio so far. Both are byproducts of our 
        training and consulting work - something that we kept re-using 
        and felt it was cheaper to ship it once and allow others to use as well.
      </p>
    </div>
  </section>

  <section class="pb-24 px-4 border-t border-border pt-16">
    <div class="container-custom max-w-desktop">
      <div class="flex flex-col gap-20 md:gap-28">
        {products.map(({ data, Content }, idx) => (
          <div class="max-w-3xl">
            <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
              Product 0{idx + 1}
            </p>
            <ProductLogo logo={data.logo} name={data.title} size="md" />
            <h2 class="mt-4 font-tight text-3xl md:text-4xl font-semibold text-ink leading-snug">
              {data.title}
            </h2>
            {data.tagline && (
              <p class="mt-2 text-base md:text-lg text-subtle">
                {data.tagline}
              </p>
            )}

            <div class="mt-6 prose prose-lg max-w-none prose-headings:font-tight prose-headings:text-ink prose-headings:font-semibold prose-p:text-body prose-p:leading-relaxed prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-strong:text-ink prose-li:text-body prose-li:leading-relaxed">
              <Content components={components} />
            </div>

            {(data.audience || data.price) && (
              <dl class="mt-8 grid grid-cols-1 md:grid-cols-2 gap-y-4 gap-x-8 text-sm border-t border-border pt-6">
                {data.audience && (
                  <div>
                    <dt class="text-xs uppercase tracking-wider text-subtle font-medium mb-1">Built for</dt>
                    <dd class="text-ink">{data.audience}</dd>
                  </div>
                )}
                {data.price && (
                  <div>
                    <dt class="text-xs uppercase tracking-wider text-subtle font-medium mb-1">Pricing</dt>
                    <dd class="text-ink">{data.price}</dd>
                  </div>
                )}
              </dl>
            )}

            {data.url && (
              <a
                href={data.url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-block mt-8 btn-primary"
              >
                Visit {data.title.replace(/[\[\]]/g, '')}
                <span aria-hidden="true">&rarr;</span>
              </a>
            )}
          </div>
        ))}
      </div>

      {products.length === 0 && (
        <p class="text-body">No published products yet.</p>
      )}
    </div>
  </section>
</Layout>
