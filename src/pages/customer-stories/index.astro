---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allStories = await getCollection('customer-stories', ({ data }) => !data.draft);
const sortedStories = allStories.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<Layout title="Customer Stories" description="See how companies are succeeding with nuefunnel">
  <section class="py-20 px-4 pt-28">
    <div class="container mx-auto max-w-[800px]">
      <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-12 text-center">
        Customer Case Studies
      </h1>

      <div class="space-y-6">
        {sortedStories.map((story) => (
          <article>
            <a href={`/customer-stories/${story.slug}`} class="flex items-start gap-6 group">
              {story.data.image && (
                <div class="w-[180px] h-[120px] flex-shrink-0 overflow-hidden rounded-lg bg-gray-100">
                  <img
                    src={story.data.image}
                    alt={story.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="flex-1 pt-1">
                <h2 class="text-lg font-semibold text-gray-900 group-hover:underline mb-1">
                  {story.data.title}
                </h2>
                <p class="text-sm text-muted-purple">
                  {formatDate(story.data.date)}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
