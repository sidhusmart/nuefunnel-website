---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allStories = await getCollection('customer-stories', ({ data }) => !data.draft);
const sortedStories = allStories.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<Layout title="Customer Stories" description="See how companies are succeeding with nuefunnel">
  <section class="py-20 px-4">
    <div class="container-custom max-w-desktop">
      <h1 class="text-5xl font-bold text-gray-900 mb-6">Customer Stories</h1>
      <p class="text-xl text-gray-600 mb-12 max-w-3xl">
        Discover how leading companies are transforming their API experience with nuefunnel.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedStories.map((story) => (
          <article class="card shadow-md">
            <a href={`/customer-stories/${story.slug}`} class="block">
              {story.data.image && (
                <div class="aspect-video overflow-hidden bg-gray-100">
                  <img
                    src={story.data.image}
                    alt={story.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="p-6">
                {story.data.company && (
                  <div class="text-sm font-medium text-primary mb-2">
                    {story.data.company}
                  </div>
                )}
                <h2 class="text-xl font-bold text-gray-900 mb-2 hover:text-primary transition-colors">
                  {story.data.title}
                </h2>
                <p class="text-sm text-gray-500 mb-3">
                  {formatDate(story.data.date)}
                </p>
                <p class="text-gray-600">
                  {story.data.description}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
