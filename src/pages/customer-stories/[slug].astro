---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('customer-stories', ({ data }) => !data.draft);
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await story.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
}
---

<Layout
  title={story.data.title}
  description={story.data.description}
  image={story.data.image}
  type="article"
>
  <article class="py-20 px-4">
    <div class="container-custom max-w-[800px]">
      {story.data.image && (
        <div class="aspect-video overflow-hidden bg-gray-100 rounded-lg mb-8">
          <img
            src={story.data.image}
            alt={story.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <header class="mb-8">
        {story.data.company && (
          <div class="text-lg font-medium text-primary mb-2">
            {story.data.company}
            {story.data.industry && <span class="text-gray-400"> • {story.data.industry}</span>}
          </div>
        )}
        <h1 class="text-5xl font-bold text-gray-900 mb-4">{story.data.title}</h1>
        <time datetime={story.data.date.toISOString()} class="text-gray-600">
          {formatDate(story.data.date)}
        </time>
      </header>

      <div class="prose prose-lg max-w-none">
        <Content />
      </div>

      <footer class="mt-12 pt-8 border-t border-gray-200">
        <a
          href="/customer-stories"
          class="text-primary hover:text-primary/80 font-medium inline-flex items-center gap-2"
        >
          ← Back to Customer Stories
        </a>
      </footer>
    </div>
  </article>
</Layout>
