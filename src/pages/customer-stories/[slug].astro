---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const stories = await getCollection('customer-stories', ({ data }) => !data.draft);
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await story.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<Layout
  title={story.data.title}
  description={story.data.description}
  image={story.data.image}
  type="article"
>
  <article class="py-20 px-4 pt-28">
    <div class="container mx-auto max-w-[720px]">
      <header class="mb-8 text-center">
        <h1 class="text-3xl md:text-4xl font-bold text-gray-900 mb-3">{story.data.title}</h1>
        <time datetime={story.data.date.toISOString()} class="text-muted-purple">
          {formatDate(story.data.date)}
        </time>
        {story.data.company && (
          <div class="mt-2 text-muted-purple">
            {story.data.company}
            {story.data.industry && <span> &bull; {story.data.industry}</span>}
          </div>
        )}
      </header>

      {story.data.image && (
        <div class="aspect-video overflow-hidden bg-gray-100 rounded-lg mb-10">
          <img
            src={story.data.image}
            alt={story.data.title}
            class="w-full h-full object-cover"
          />
        </div>
      )}

      <div class="prose prose-lg max-w-none prose-headings:text-gray-900 prose-headings:font-bold prose-p:text-gray-600 prose-p:leading-relaxed prose-a:text-accent-cyan prose-a:no-underline hover:prose-a:underline prose-strong:text-gray-700 prose-li:text-gray-600">
        <Content />
      </div>

      <footer class="mt-12 pt-8 border-t border-gray-200">
        <a
          href="/customer-stories"
          class="text-accent-cyan hover:underline font-medium inline-flex items-center gap-2"
        >
          &larr; Back to Customer Stories
        </a>
      </footer>
    </div>
  </article>
</Layout>
