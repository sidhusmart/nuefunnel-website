---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<Layout title="Blog" description="Insights and updates from the nuefunnel team">
  <section class="py-20 px-4 pt-28">
    <div class="container mx-auto max-w-[800px]">
      <h1 class="text-4xl md:text-5xl font-bold text-accent-cyan mb-12 text-center">
        Blog posts
      </h1>

      <div class="space-y-6">
        {sortedPosts.map((post) => (
          <article>
            <a href={`/blog/${post.slug}`} class="flex items-start gap-6 group">
              {post.data.image && (
                <div class="w-[180px] h-[120px] flex-shrink-0 overflow-hidden rounded-lg bg-gray-100">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="flex-1 pt-1">
                <h2 class="text-lg font-semibold text-gray-900 group-hover:underline mb-1">
                  {post.data.title}
                </h2>
                <p class="text-sm text-muted-purple">
                  {formatDate(post.data.date)}
                </p>
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
