---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', {
    year: 'numeric',
    month: 'short',
    day: 'numeric'
  });
}
---

<Layout title="Blog" description="Insights and updates from the nuefunnel team">
  <section class="py-20 px-4">
    <div class="container mx-auto max-w-[700px]">
      <h1 class="text-5xl font-bold text-gray-900 mb-6">Blog</h1>
      <p class="text-xl text-gray-600 mb-12">
        Insights, updates, and best practices for API development and developer experience.
      </p>

      <div class="space-y-8">
        {sortedPosts.map((post) => (
          <article class="card overflow-hidden shadow-md">
            <a href={`/blog/${post.slug}`} class="block">
              {post.data.image && (
                <div class="aspect-video overflow-hidden bg-gray-100">
                  <img
                    src={post.data.image}
                    alt={post.data.title}
                    class="w-full h-full object-cover"
                  />
                </div>
              )}
              <div class="p-6">
                <h2 class="text-2xl font-bold text-gray-900 mb-2 hover:text-primary transition-colors">
                  {post.data.title}
                </h2>
                <p class="text-sm text-gray-500 mb-3">
                  {formatDate(post.data.date)}
                </p>
                <p class="text-gray-600">
                  {post.data.description}
                </p>
                {post.data.tags && post.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-2 mt-4">
                    {post.data.tags.map((tag) => (
                      <span class="px-3 py-1 text-xs font-medium bg-primary/10 text-primary rounded-full">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</Layout>
