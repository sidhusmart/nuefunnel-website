---
import Layout from '../layouts/Layout.astro';
---

<Layout title="nuefunnel">
  <!-- Hero Section -->
  <section class="py-20 px-4">
    <div class="container-custom max-w-desktop">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-6xl font-bold text-gray-900 mb-6">
          Simplify API usage with AI-powered chat assistance
        </h1>
        <p class="text-xl md:text-2xl text-gray-600 mb-8 max-w-3xl mx-auto">
          Turn your API documentation into an interactive experience. Our AI assistant bridges
          the gap between complex APIs and developer success.
        </p>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2 text-lg"
        >
          Request Demo
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 px-4 bg-gray-50">
    <div class="container-custom max-w-desktop">
      <h2 class="text-3xl md:text-4xl font-bold text-center text-gray-900 mb-16">
        Enhance user experience, reduce support overhead, and fuel creative solutions
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        <!-- Feature 1 -->
        <div class="card p-8 shadow-lg">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Instant and Accurate</h3>
          <p class="text-gray-600 leading-relaxed">
            Aims to reduce response time and improve developer satisfaction through AI-driven,
            instant answers to technical and user queries.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="card p-8 shadow-lg">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 11.5V14m0-2.5v-6a1.5 1.5 0 113 0m-3 6a1.5 1.5 0 00-3 0v2a7.5 7.5 0 0015 0v-5a1.5 1.5 0 00-3 0m-6-3V11m0-5.5v-1a1.5 1.5 0 013 0v1m0 0V11m0-5.5a1.5 1.5 0 013 0v3m0 0V11"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Boost API Adoption</h3>
          <p class="text-gray-600 leading-relaxed">
            Simplifies complex API usage, making it easier for developers to integrate your APIs
            and drive innovative product development.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="card p-8 shadow-lg">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Enhance Documentation</h3>
          <p class="text-gray-600 leading-relaxed">
            Fills gaps in existing documentation by providing dynamic, contextual responses
            that evolve with your APIs.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="card p-8 shadow-lg">
          <div class="w-12 h-12 bg-primary/10 rounded-lg flex items-center justify-center mb-4">
            <svg class="w-6 h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6V4m0 2a2 2 0 100 4m0-4a2 2 0 110 4m-6 8a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4m6 6v10m6-2a2 2 0 100-4m0 4a2 2 0 110-4m0 4v2m0-6V4"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 mb-4">Streamline Workflows</h3>
          <p class="text-gray-600 leading-relaxed">
            Frees up your team from answering repetitive questions, allowing them to focus
            on higher-value tasks.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4">
    <div class="container-custom max-w-desktop">
      <div class="text-center bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl p-12">
        <h2 class="text-3xl md:text-4xl font-bold text-gray-900 mb-6">
          Ready to transform your API experience?
        </h2>
        <p class="text-xl text-gray-600 mb-8">
          Get started with nuefunnel today and see the difference AI can make.
        </p>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2 text-lg"
        >
          Request Demo
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </section>
</Layout>
