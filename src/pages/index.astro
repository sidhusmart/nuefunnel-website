---
import Layout from '../layouts/Layout.astro';
---

<Layout title="nuefunnel">
  <!-- Hero Section -->
  <section class="py-20 px-4 pt-28">
    <div class="container-custom max-w-desktop">
      <div class="text-center max-w-4xl mx-auto">
        <h1 class="text-5xl md:text-7xl font-bold gradient-text mb-6">
          Simplify API usage with AI-powered chat assistance
        </h1>
        <p class="text-xl md:text-2xl text-muted-purple mb-8 max-w-3xl mx-auto">
          Turn your API documentation into an interactive experience. Our AI assistant bridges
          the gap between complex APIs and developer success.
        </p>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2 text-lg"
        >
          Request Demo
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Benefits Section -->
  <section class="py-16 px-4">
    <div class="container-custom max-w-desktop">
      <h2 class="text-2xl md:text-3xl font-medium text-center gradient-text-italic mb-16 max-w-3xl mx-auto">
        Enhance user experience, reduce support overhead, and fuel creative solutions
      </h2>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 max-w-5xl mx-auto">
        <!-- Feature 1 -->
        <div class="rounded-xl p-8 text-center" style="background: linear-gradient(180deg, rgba(229, 221, 255, 0.2) 0%, rgba(229, 221, 255, 0.4) 100%);">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-muted-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-muted-purple mb-3">Instant and Accurate</h3>
          <p class="text-muted-purple/80 leading-relaxed">
            Reduce response time and improve developer satisfaction with AI-driven,
            instant answers to technical and user queries.
          </p>
        </div>

        <!-- Feature 2 -->
        <div class="rounded-xl p-8 text-center" style="background: linear-gradient(180deg, rgba(229, 221, 255, 0.2) 0%, rgba(229, 221, 255, 0.4) 100%);">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-muted-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-muted-purple mb-3">Boost API Adoption</h3>
          <p class="text-muted-purple/80 leading-relaxed">
            Simplify complex API usage, making it easier for developers to integrate your APIs
            and drive innovative product development.
          </p>
        </div>

        <!-- Feature 3 -->
        <div class="rounded-xl p-8 text-center" style="background: linear-gradient(180deg, rgba(229, 221, 255, 0.2) 0%, rgba(229, 221, 255, 0.4) 100%);">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-muted-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-muted-purple mb-3">Enhance Documentation</h3>
          <p class="text-muted-purple/80 leading-relaxed">
            Fill gaps in existing documentation by providing dynamic, contextual responses
            that evolve with your APIs.
          </p>
        </div>

        <!-- Feature 4 -->
        <div class="rounded-xl p-8 text-center" style="background: linear-gradient(180deg, rgba(229, 221, 255, 0.2) 0%, rgba(229, 221, 255, 0.4) 100%);">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-muted-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-muted-purple mb-3">Streamline Workflows</h3>
          <p class="text-muted-purple/80 leading-relaxed">
            Free up your team from answering repetitive questions, allowing them to focus
            on higher-value tasks.
          </p>
        </div>
      </div>

      <!-- Fifth card - full width centered -->
      <div class="max-w-2xl mx-auto mt-6">
        <div class="rounded-xl p-8 text-center" style="background: linear-gradient(180deg, rgba(229, 221, 255, 0.2) 0%, rgba(229, 221, 255, 0.4) 100%);">
          <div class="w-12 h-12 mx-auto mb-4 flex items-center justify-center">
            <svg class="w-8 h-8 text-muted-purple" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 4a2 2 0 114 0v1a1 1 0 001 1h3a1 1 0 011 1v3a1 1 0 01-1 1h-1a2 2 0 100 4h1a1 1 0 011 1v3a1 1 0 01-1 1h-3a1 1 0 01-1-1v-1a2 2 0 10-4 0v1a1 1 0 01-1 1H7a1 1 0 01-1-1v-3a1 1 0 00-1-1H4a2 2 0 110-4h1a1 1 0 001-1V7a1 1 0 011-1h3a1 1 0 001-1V4z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold text-muted-purple mb-3">Seamless Integration</h3>
          <p class="text-muted-purple/80 leading-relaxed">
            Easily integrate the AI assistant into your existing documentation and support systems,
            offering a smooth user experience.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-20 px-4">
    <div class="container-custom max-w-desktop">
      <div class="text-center">
        <h2 class="text-4xl md:text-5xl font-bold gradient-text mb-8">
          Sign up today.
        </h2>
        <a
          href="https://tally.so/r/w2JM7g"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary inline-flex items-center gap-2 text-lg"
        >
          Get Started
        </a>
      </div>
    </div>
  </section>
</Layout>
