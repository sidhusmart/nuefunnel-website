---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import FounderAvatar from '../components/FounderAvatar.astro';

// Single source of truth for founder profiles (shared with /about).
const founders = (await getCollection('team')).sort(
  (a, b) => a.data.order - b.data.order
);

// Pull the three most-recent work entries from the collection so this stays
// in sync with /work automatically. Drafts are excluded.
const allWork = await getCollection('work', ({ data }) => !data.draft);
const caseStudies = allWork
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((entry) => ({
    slug: entry.slug,
    industry: entry.data.industry ?? '',
    headline: entry.data.title,
    outcome: entry.data.outcome ?? entry.data.description,
    scope: entry.data.scope ?? '',
    detail: entry.data.description,
  }));

const products = [
  {
    name: '[Product one]',
    tagline: 'AI-assisted [specific category]',
    body: 'We built [Product one] after seeing the same problem at three different clients. It does the one specific thing they all needed, without the platform-y bloat we kept refusing to add.',
    href: 'https://[product-one].com',
  },
  {
    name: '[Product two]',
    tagline: 'Lightweight [specific tool] for small teams',
    body: 'A small utility we use ourselves on every engagement. Public so other operators can use it too. Not a business — just a useful thing.',
    href: 'https://[product-two].com',
  },
];

// Pull the four most-recent blog posts from the collection.
const allBlog = await getCollection('blog', ({ data }) => !data.draft);
const writing = allBlog
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 4)
  .map((entry) => ({
    type: 'Post',
    title: entry.data.title,
    meta: entry.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric' }),
    href: `/blog/${entry.slug}`,
  }));
---

<Layout title="nuefunnel">
  <!-- Hero -->
  <section class="pt-28 md:pt-36 pb-20 px-4">
    <div class="container-custom max-w-desktop">
      <div class="flex flex-wrap gap-x-12 gap-y-6 mb-14">
        {founders.map((f) => (
          <div class="flex items-center gap-4">
            <FounderAvatar
              photo={f.data.photo}
              initials={f.data.initials}
              name={f.data.name}
              size="sm"
              loading="eager"
            />
            <div>
              <p class="text-ink font-medium leading-tight">{f.data.name}</p>
              <p class="text-subtle text-sm leading-tight mt-1">{f.data.role}</p>
            </div>
          </div>
        ))}
      </div>

      <h1 class="font-tight text-5xl md:text-7xl font-semibold text-ink max-w-4xl leading-[1.05]">
        Shipping AI products with small teams.
      </h1>

      <p class="mt-8 text-lg md:text-xl text-body max-w-2xl leading-relaxed">
        We're a two-person studio. We build our own products, take on a small number
        of consulting projects each quarter, and run corporate training when invited.
      </p>

      <div class="mt-10 flex flex-wrap gap-3">
        <a
          href="mailto:contact@nuefunnel.com?subject=Project%20inquiry"
          class="btn-primary"
        >
          Start a project
        </a>
        <a href="/work" class="btn-secondary">
          See the work
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Recent work -->
  <section class="py-20 md:py-28 px-4 border-t border-border">
    <div class="container-custom max-w-desktop">
      <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-3">
        Recent work
      </p>
      <h2 class="font-tight text-3xl md:text-5xl font-semibold text-ink max-w-3xl leading-[1.1]">
        Three of the last five engagements.
      </h2>

      <div class="mt-14 flex flex-col gap-12 md:gap-16">
        {caseStudies.map((c) => (
          <a
            href={`/work/${c.slug}`}
            class="block group max-w-3xl"
          >
            <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
              {c.industry}
            </p>
            <h3 class="font-tight text-2xl md:text-3xl font-semibold text-ink group-hover:text-accent transition-colors">
              {c.headline}
            </h3>
            <p class="mt-3 text-body text-base md:text-lg leading-relaxed">
              {c.outcome}
            </p>
            <p class="mt-4 text-sm text-subtle font-medium">
              {c.scope}
            </p>
            <p class="mt-2 text-sm text-subtle italic">
              {c.detail}
            </p>
          </a>
        ))}
      </div>

      <div class="mt-14">
        <a href="/work" class="text-accent font-medium hover:text-accent-hover">
          See all work <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Built things -->
  <section class="py-20 md:py-28 px-4 border-t border-border">
    <div class="container-custom max-w-desktop">
      <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-3">
        Built things
      </p>
      <h2 class="font-tight text-3xl md:text-5xl font-semibold text-ink max-w-3xl leading-[1.1]">
        Products we've built, mostly because we needed them ourselves.
      </h2>

      <div class="mt-14 grid grid-cols-1 md:grid-cols-2 gap-10 md:gap-16">
        {products.map((p) => (
          <div>
            <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
              Product
            </p>
            <h3 class="font-tight text-2xl md:text-3xl font-semibold text-ink">
              {p.name}
            </h3>
            <p class="mt-2 text-base text-subtle">
              {p.tagline}
            </p>
            <p class="mt-4 text-body leading-relaxed">
              {p.body}
            </p>
            <a
              href={p.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-block mt-5 text-accent font-medium hover:text-accent-hover"
            >
              Visit {p.name.replace(/[\[\]]/g, '')} <span aria-hidden="true">&rarr;</span>
            </a>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Blog -->
  <section class="py-20 md:py-28 px-4 border-t border-border">
    <div class="container-custom max-w-desktop">
      <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-3">
        Blog
      </p>
      <h2 class="font-tight text-3xl md:text-5xl font-semibold text-ink max-w-3xl leading-[1.1]">
        Our latest thinking - drawn from our work, research and consulting.
      </h2>

      <ul class="mt-14 divide-y divide-border border-t border-border max-w-3xl">
        {writing.map((w) => (
          <li>
            <a
              href={w.href}
              class="flex flex-col md:flex-row md:items-baseline md:gap-6 py-6 group"
            >
              <span class="text-xs uppercase tracking-wider text-subtle font-medium md:w-20 md:flex-shrink-0 mb-1 md:mb-0">
                {w.type}
              </span>
              <span class="flex-1">
                <span class="block font-tight text-lg md:text-xl font-medium text-ink group-hover:text-accent transition-colors leading-snug">
                  {w.title}
                </span>
                <span class="block text-sm text-subtle mt-1">
                  {w.meta}
                </span>
              </span>
            </a>
          </li>
        ))}
      </ul>

      <div class="mt-10">
        <a href="/blog" class="text-accent font-medium hover:text-accent-hover">
          Read the blog <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </section>

  <!-- Engagement -->
  <section class="py-20 md:py-28 px-4 border-t border-border">
    <div class="container-custom max-w-desktop">
      <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-3">
        Working with us
      </p>
      <h2 class="font-tight text-3xl md:text-5xl font-semibold text-ink max-w-3xl leading-[1.1]">
        Three ways we take on work.
      </h2>

      <div class="mt-8 max-w-2xl">
        <p class="text-body text-base md:text-lg leading-relaxed">
          Small scope, two people, mostly coding-agent-assisted. We don't take on
          enterprise compliance work, staff augmentation, or ML-platform builds.
          For a sense of what this looks like in practice, <a href="/work" class="text-accent hover:text-accent-hover underline underline-offset-4 decoration-1">see what we've built</a> or take a look at <a href="/training" class="text-accent hover:text-accent-hover underline underline-offset-4 decoration-1">training workshops we've run</a>.
          If you're unsure whether what you have in mind fits, send us a short note
          and we'll tell you honestly.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-12">
        <div>
          <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
            Project work
          </p>
          <h3 class="font-tight text-xl font-semibold text-ink leading-snug">
            Build something specific.
          </h3>
          <p class="mt-3 text-body leading-relaxed">
            Four to eight weeks, two people. Best for a defined deliverable you
            can describe in a paragraph.
          </p>
          <a
            href="mailto:contact@nuefunnel.com?subject=Project%20inquiry"
            class="inline-block mt-4 text-accent font-medium hover:text-accent-hover"
          >
            Start a project <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
            Training
          </p>
          <h3 class="font-tight text-xl font-semibold text-ink leading-snug">
            Workshops, not generic AI 101.
          </h3>
          <p class="mt-3 text-body leading-relaxed">
            Workshop-led sessions for small audiences, curated to your team's
            actual work, business context, and daily tasks.
          </p>
          <a
            href="mailto:contact@nuefunnel.com?subject=Training%20inquiry"
            class="inline-block mt-4 text-accent font-medium hover:text-accent-hover"
          >
            Request a workshop <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
        <div>
          <p class="text-xs uppercase tracking-wider text-subtle font-medium mb-2">
            Pro-bono
          </p>
          <h3 class="font-tight text-xl font-semibold text-ink leading-snug">
            A few slots a year, free.
          </h3>
          <p class="mt-3 text-body leading-relaxed">
            We take on a limited amount of pro-bono work &mdash; typically for
            non-profits, sometimes for groups of individuals supporting a cause.
          </p>
          <a
            href="mailto:contact@nuefunnel.com?subject=Pro-bono%20inquiry"
            class="inline-block mt-4 text-accent font-medium hover:text-accent-hover"
          >
            Tell us about the cause <span aria-hidden="true">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</Layout>
