# build output
dist/
.output/

# generated optimized images (created at build time)
public/images/optimized/

# dependencies
node_modules/

# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# environment variables
.env
.env.production

# macOS-specific files
.DS_Store

# jetbrains setting folders
.idea/

# VS Code settings (workspace settings.json is intentionally tracked)
.vscode/
!.vscode/settings.json

# bv (beads viewer) local config and caches
.bv/

# Astro's generated cache (types, settings, content-collection types).
# Regenerated by `astro sync` / dev / build — never commit.
.astro/

# Local agent / Claude Code / MCP state (not for sharing)
.claude/
.agents/
.mcp.json
skills-lock.json

# Framer migration artifacts (raw exports + downloaded images stay local;
# only the script and decisions.csv are tracked so the migration is reproducible)
migration/exports/
migration/images/
migration/staging/
# Numbers-exported working copy of decisions.csv (semicolon-delimited, gets
# canonicalized into the tracked decisions.csv by verify-decisions.mjs --write)
migration/decisions_updated.csv
